---
// src/pages/diario.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CustomCursor from '../components/CustomCursor.astro';
import { Image } from 'astro:assets';

// --- CARGA AUTOMÁTICA DE IMÁGENES (DIARIO) ---
// Busca archivos que empiecen con "diario" (diario1, diario2...)
const imageFiles = import.meta.glob('../assets/images/diario*.{jpeg,jpg,png,webp}', { eager: true });

const portfolioItems = Object.entries(imageFiles)
  .map(([path, module]: [string, any]) => {
    // Extraemos el número del nombre del archivo
    const match = path.match(/diario(\d+)\./);
    const number = match ? parseInt(match[1]) : 0;
    
    return {
      img: module.default,
      alt: `Diario Visual / Street Photography - Uli Vergara ${number}`,
      order: number
    };
  })
  .sort((a, b) => a.order - b.order); // Ordenamos del 1 al 41
---

<Layout title="Diario | Uli Vergara">
    <CustomCursor />
    <Header />

    <main class="min-h-screen w-full bg-black text-white pt-40 pb-20 px-6 md:px-12">

        <div class="max-w-4xl mx-auto text-center mb-24 animate-intro-text">
            <h1 class="text-xs font-bold tracking-[0.5em] uppercase text-white/50 mb-6">
                Diario Visual
            </h1>
            <h2 class="text-5xl md:text-7xl font-serif tracking-wide uppercase leading-tight">
                Lo que observo.
            </h2>
             <p class="mt-8 text-sm md:text-base text-white/70 max-w-xl mx-auto leading-relaxed tracking-wider font-light">
                Aquí guardo los fragmentos de luz que me encuentro.
            </p>
            <div class="mt-12 h-px w-24 bg-white/30 mx-auto"></div>
        </div>


        <section class="columns-1 md:columns-2 lg:columns-3 gap-4 md:gap-8 space-y-4 md:space-y-8 trigger-custom-cursor">
            
            {portfolioItems.map((item) => (
                <div class="break-inside-avoid relative group rounded-sm overflow-hidden reveal-on-scroll">
                    
                    <Image 
                        src={item.img} 
                        alt={item.alt}
                        class="w-full h-auto object-cover transition-transform duration-700 ease-out group-hover:scale-[1.02]"
                        width={800} 
                        quality="mid"
                        loading="lazy"
                    />
                    
                    <div class="absolute inset-0 bg-black/10 transition-opacity duration-500 group-hover:opacity-0 pointer-events-none"></div>
                </div>
            ))}

        </section>
        
        <div class="mt-32 text-center reveal-on-scroll">
            <p class="text-white/50 text-sm tracking-[0.2em] uppercase mb-6">Quieres comprar un print?</p>
            <a href="/agenda" class="inline-block border border-white/30 px-12 py-4 text-xs font-bold tracking-[0.3em] uppercase hover:bg-white hover:text-black hover:border-white transition-all duration-500">
                Contáctame
            </a>
        </div>

    </main>
</Layout>


<style>
    /* --- ANIMACIONES CSS --- */
    .animate-intro-text {
        animation: fadeUpIntro 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        opacity: 0;
        transform: translateY(30px);
    }
    @keyframes fadeUpIntro {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .reveal-on-scroll {
        opacity: 0;
        transform: translateY(50px) scale(0.98); 
        transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .reveal-on-scroll.is-visible {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
</style>


<script>
    // --- SCRIPT PROTEGIDO ---
    document.addEventListener('astro:page-load', () => {

        const revealElements = document.querySelectorAll('.reveal-on-scroll');

        if (revealElements.length === 0) return;

        const revealOptions = {
            threshold: 0.15,
            rootMargin: "0px 0px -50px 0px"
        };

        const revealOnScroll = new IntersectionObserver(function(entries, observer) {
            entries.forEach(entry => {
                if (!entry.isIntersecting) {
                    return;
                }
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
            });
        }, revealOptions);

        revealElements.forEach(el => {
            revealOnScroll.observe(el);
        });
    });
</script>